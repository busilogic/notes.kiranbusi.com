---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PostCard from '../../components/PostCard.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base
  title="Writing"
  description="Essays and observations on cloud architecture, engineering leadership, and AI in practice."
>
  <div class="page-header">
    <h1 class="page-header__title">Writing</h1>
  </div>

  {posts.length === 0 ? (
    <p class="post-list__empty">More coming soon.</p>
  ) : (
    <ul class="post-list">
      {posts.map((post) => (
        <li>
          <PostCard
            title={post.data.title}
            date={post.data.date}
            description={post.data.description}
            slug={post.slug}
          />
        </li>
      ))}
    </ul>
  )}

  <div class="archive-section">
    <h2 class="archive-section__heading">Earlier writing <span class="archive-section__year">2015–2018</span></h2>
    <ul class="archive-list">
      <li><a href="/archive/REST-Api-best-practices.html">REST API Best Practices</a></li>
      <li><a href="/archive/emacs-with-gpg2.html">Emacs with GPG2</a></li>
      <li><a href="/archive/freebsd.html">FreeBSD Notes</a></li>
    </ul>
  </div>
</Base>
