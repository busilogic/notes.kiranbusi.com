---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';

const allPosts = await getCollection('posts', ({ data }) => !data.draft);
const posts = allPosts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf()).slice(0, 5);
---

<Base
  title="Kiran Busi"
  description="Principal Consultant in cloud architecture, enterprise AI, and engineering leadership."
>
  <div class="home-statement">
    <p class="home-statement__lede">
      Principal Consultant and team lead. Cloud architecture, enterprise AI, and helping technical teams do better work.
    </p>
  </div>

  <ul class="post-list">
    {posts.map((post) => (
      <li>
        <PostCard
          title={post.data.title}
          date={post.data.date}
          description={post.data.description}
          slug={post.slug}
        />
      </li>
    ))}
  </ul>
</Base>
